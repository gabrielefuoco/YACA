PORT=7000
# URL pubblico del server (obbligatorio se l'addon è ospitato su un server/VPS remoto)
# Necessario per generare correttamente gli URL dei poster con badge episodio.
# HOST_URL=https://tuo-dominio-o-ip.com
# API Keys globali gestite dal server (gli utenti non devono inserirle)
# TMDB_API_KEY=
# MISTRAL_API_KEY=
# Opzionale: Trakt.tv integration
# TRAKT_CLIENT_ID=
# TRAKT_CLIENT_SECRET=
# Opzionale: lista di origini CORS consentite, separate da virgola (default: tutte le origini)
# CORS_ALLOWED_ORIGINS=https://miosito.com,https://altro.com
# Redis URL (default: redis://127.0.0.1:6379 — auto-started in Docker)
# REDIS_URL=redis://127.0.0.1:6379

# Chiave crittografica per la crittografia a riposo dei dati sensibili (API keys) su MongoDB.
# Deve essere una stringa di almeno 32 caratteri. OBBLIGATORIA per abilitare la crittografia.
# Generare con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DATABASE_ENCRYPTION_KEY=

# === NextAuth.js (Autenticazione) ===
# Segreto per firmare e cifrare i JWT dei cookie HttpOnly.
# OBBLIGATORIO per l'autenticazione. Generare con: openssl rand -base64 32
# NEXTAUTH_SECRET=

# URL canonico e pubblico dell'applicazione. Necessario per il redirect post-login.
# In sviluppo locale: http://localhost:7000
# In produzione (Hugging Face Spaces): https://nome-spazio.hf.space
# AUTH_URL=https://nome-spazio.hf.space
# AUTH_TRUST_HOST=true
# NEXTAUTH_URL=https://nome-spazio.hf.space
AUTH_URL=http://localhost:7000
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:7000
