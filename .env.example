PORT=7000
# URL pubblico del server (obbligatorio se l'addon è ospitato su un server/VPS remoto)
# Necessario per generare correttamente gli URL dei poster con badge episodio.
# HOST_URL=https://tuo-dominio-o-ip.com
# API Keys globali gestite dal server (gli utenti non devono inserirle)
# TMDB_API_KEY=
# MISTRAL_API_KEY= (BYOK only — server fallback disabilitato per AI generation)
# Opzionale: Trakt.tv integration
# TRAKT_CLIENT_ID=
# TRAKT_CLIENT_SECRET=
# Opzionale: lista di origini CORS consentite, separate da virgola (default: tutte le origini)
# CORS_ALLOWED_ORIGINS=https://miosito.com,https://altro.com
# Redis URL (default: redis://127.0.0.1:6379 — auto-started in Docker)
# REDIS_URL=redis://127.0.0.1:6379
# JWT Secret per autenticazione HttpOnly Cookie (obbligatorio)
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# JWT_SECRET=
