# ╔══════════════════════════════════════════════════════════════════╗
# ║  YACA — Secrets per GitHub Actions                             ║
# ║                                                                ║
# ║  1. Copia questo file: cp secrets.env.example secrets.env      ║
# ║  2. Compila i valori                                           ║
# ║  3. Esegui: gh secret set -f secrets.env                       ║
# ║                                                                ║
# ║  ⚠️ NON committare secrets.env!  (è già in .gitignore)         ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── OBBLIGATORI ──────────────────────────────────────────────────

# Hugging Face
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_SPACE_ID=il-tuo-username/YACA

# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/yaca

# TMDB (per cataloghi e metadati)
TMDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CLOUDFLARE WORKER (proxy anti-ban) ───────────────────────────

CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── STREAM PROXY ─────────────────────────────────────────────────

# URL del tuo addon Stremio per gli stream (es. IlCorsaroViola)
PROXY_ADDON_URL=https://icv.stremio-italia.eu/xxxxxx/manifest.json

# ── OPZIONALI ────────────────────────────────────────────────────

# Auth (se non impostato, viene generato casualmente ad ogni riavvio)
# JWT_SECRET=una-stringa-segreta-lunga-e-casuale

# EasyRatingsDB (badge qualità)
# ERDB_CONFIG=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI Discovery (catalogo AI)
# MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Trakt (sincronizzazione watchlist)
# TRAKT_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TRAKT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL pubblico dello Space (auto-rilevato su HF, impostalo solo se usi un dominio custom)
# HOST_URL=https://il-tuo-username-yaca.hf.space
HF_BUCKET_NAME=your-bucket-name
